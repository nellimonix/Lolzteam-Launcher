{
  "name": "@lolzteam/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Lolzteam Launcher — desktop app",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@mtcute/convert": "^0.29.7",
    "@mtcute/node": "^0.29.7",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.8.3",
    "ky": "^1.7.4",
    "steam-session": "^1.9.2"
  },
  "devDependencies": {
    "@lolzteam/adapter-contract": "workspace:*",
    "@lolzteam/market-sdk": "workspace:*",
    "@lolzteam/shared-ipc": "workspace:*",
    "@lolzteam/shared-types": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.92.0",
    "@tanstack/router-vite-plugin": "^1.92.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "i18next": "^26.3.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.7",
    "zustand": "^5.0.2"
  },
  "build": {
    "appId": "com.lolzteam.launcher",
    "productName": "Lolzteam Launcher",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.cjs",
    "files": [
      "out/**/*",
      "package.json",
      "!node_modules/better-sqlite3/{deps,build/Release/obj,src}/**",
      "!node_modules/**/*.{c,cc,cpp,h,hpp,ts,map,md,markdown}",
      "!node_modules/**/{test,tests,__tests__,example,examples,docs,.github}/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "protocols": [
      {
        "name": "Lolzteam Launcher",
        "schemes": [
          "lolzteamlauncher"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "iamextasy",
        "repo": "Lolzteam-Launcher"
      }
    ]
  }
}
